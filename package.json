{
  "name": "lxd-ui",
  "version": "0.0.1",
  "author": "Canonical Webteam",
  "license": "LGPL-3.0-only",
  "type": "module",
  "scripts": {
    "clean": "rm -rf node_modules yarn-error.log *.log build/",
    "build-html": "cp build/ui/index.html build/index.html",
    "build-monaco": "mkdir build/ui/monaco-editor && cp -R node_modules/monaco-editor/min build/ui/monaco-editor",
    "build": "npx vite build && yarn build-html && yarn build-monaco",
    "start": "vite --host"
  },
  "dependencies": {
    "@canonical/react-components": "3.6.0",
    "@monaco-editor/react": "4.6.0",
    "@tanstack/react-query": "5.63.0",
    "axios": "1.12.0",
    "formik": "2.4.6",
    "ip-address": "^10.0.1",
    "js-yaml": "4.1.1",
    "lodash.isequal": "4.5.0",
    "node-forge": "1.3.1",
    "parse-prometheus-text-format": "1.1.1",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-router-dom": "7.5.2",
    "serve": "14.2.4",
    "vanilla-framework": "4.37.0",
    "@xterm/xterm": "5.5.0",
    "@xterm/addon-fit": "0.10.0",
    "yup": "1.6.1"
  },
  "devDependencies": {
    "@babel/eslint-parser": "7.25.9",
    "@babel/preset-react": "7.26.3",
    "@babel/preset-typescript": "7.26.0",
    "@canonical/typescript-config-react": "0.9.0",
    "@playwright/test": "1.49.1",
    "@types/convert-source-map": "2.0.3",
    "@types/dotenv": "8.2.3",
    "@types/js-yaml": "4.0.9",
    "@types/lodash.isequal": "4.5.8",
    "@types/node-forge": "1.3.11",
    "@types/react": "19.0.10",
    "@types/react-dom": "19.0.4",
    "@types/websocket": "1.0.10",
    "@typescript-eslint/eslint-plugin": "8.19.1",
    "@typescript-eslint/parser": "8.19.1",
    "@vitejs/plugin-react": "4.3.4",
    "@vitest/coverage-istanbul": "2.1.8",
    "autoprefixer": "10.4.20",
    "babel-plugin-istanbul": "7.0.0",
    "concurrently": "9.1.2",
    "convert-source-map": "2.0.0",
    "eslint": "9.17.0",
    "dotenv": "16.4.7",
    "eslint-config-prettier": "9.1.0",
    "eslint-plugin-prettier": "5.2.1",
    "eslint-plugin-react": "7.37.3",
    "husky": "9.1.7",
    "lint-staged": "15.3.0",
    "monaco-editor": "0.52.2",
    "nyc": "17.1.0",
    "postcss": "8.4.49",
    "postcss-cli": "11.0.0",
    "prettier": "3.4.2",
    "sass": "1.83.1",
    "stylelint": "16.12.0",
    "stylelint-config-standard-scss": "14.0.0",
    "stylelint-order": "6.0.4",
    "stylelint-prettier": "5.0.2",
    "stylelint-scss": "6.10.0",
    "typescript": "5.7.3",
    "v8-to-istanbul": "9.3.0",
    "vite": "6.4.1",
    "vite-plugin-istanbul": "6.0.2",
    "vite-tsconfig-paths": "5.1.4",
    "vitest": "3.0.9"
  },
  "lint-staged": {
    "src/**/*.{json,jsx,ts,tsx}": [
      "eslint",
      "prettier --check"
    ],
    "tests/**/*.{json,jsx,ts,tsx}": [
      "eslint",
      "prettier --check"
    ],
    "src/**/*.scss": "stylelint"
  },
  "resolutions": {
    "path-to-regexp": "8.2.0",
    "wrap-ansi": "7.0.0"
  }
}
